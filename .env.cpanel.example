APP_NAME="Saidi Papetrie"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Algiers
APP_URL=https://votre-domaine.dz

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (from cPanel → MySQL Databases) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpuser_saidi
DB_USERNAME=cpuser_admin
DB_PASSWORD=

# On shared hosting, file-based drivers are the safest defaults:
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=mail.votre-domaine.dz
MAIL_PORT=465
MAIL_USERNAME=contact@votre-domaine.dz
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="contact@votre-domaine.dz"
MAIL_FROM_NAME="${APP_NAME}"

# --- Delivery integrations ---
NOEST_ENABLED=false
NOEST_BASE_URL=https://app.noest-dz.com
NOEST_API_TOKEN=
NOEST_GUID=

YALIDINE_ENABLED=false
YALIDINE_BASE_URL=https://api.yalidine.app/v1
YALIDINE_API_ID=
YALIDINE_API_TOKEN=

STORE_DEFAULT_DELIVERY_FEE=600
STORE_FREE_SHIPPING_THRESHOLD=0
